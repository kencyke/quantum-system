module

public import QuantumSystem.ForMathlib.Analysis.InnerProductSpace.DiagonalAmplification
public import QuantumSystem.ForMathlib.Analysis.InnerProductSpace.InvariantSubspace
public import QuantumSystem.ForMathlib.Analysis.LocallyConvex.WeakOperatorTopology

/-!
# The double commutant theorem (hard half)

This file contains the proof of (a weak-operator-topology form of) von Neumann's
*double commutant theorem*.

## Background and goal

Mathlib packages von Neumann algebras using the algebraic characterization: a `StarSubalgebra` is a
von Neumann algebra when it equals its double commutant (implemented via `Set.centralizer`).
Classically, for a `*-`subalgebra of bounded operators on a Hilbert space, this algebraic condition
is equivalent to being closed in the weak operator topology (WOT).

The "hard half" is the direction

*WOT-closed `*-`subalgebra* ⇒ *equals its double commutant*.

We state and prove this as an equality of sets of operators
`Set.centralizer (Set.centralizer (A : Set B)) = (A : Set B)`.

## What this file contains

This file provides the main theorem `doubleCommutant_eq_of_isWOTClosed` and the intermediate
infrastructure used in its proof. The key objects are:

* `cyclicSubspace A x`: the closed subspace generated by the orbit `A • x`.
  It is shown to be *reducing* for `A`.
* `PreservesReducingSubspaces S T`: a predicate saying that `T` leaves invariant every
  `S`-reducing subspace (and its orthogonal complement).
* `reducingHull S`: the set of all operators preserving every `S`-reducing subspace.
  This is an "AlgLat"-style hull but using *reducing* (not just invariant) subspaces.

The first conceptual step is a structural consequence of double commutant membership:

* if `T ∈ S''` then `T ∈ reducingHull S` (see `centralizer_centralizer_subset_reducingHull`).

This is proved by showing that for any `S`-reducing subspace `K`, the orthogonal projection onto `K`
lies in `S'`, hence commutes with any `T ∈ S''`, and commutation with the projection implies
invariance of both `K` and `Kᗮ`.

## Proof strategy (high level)

To prove the hard-half statement `A'' ⊆ A`, we argue by separation:

1. Assume `T ∉ A`; since `A` is WOT-closed, find a WOT-continuous linear functional `f` separating
   `T` from `A` (via `exists_wotCLM_sep_of_isClosed_submodule_sum`).
2. Rewrite `f` as a *finite* sum of matrix coefficients; this is encoded in the separating
   functional returned by the separation lemma.
3. Construct the diagonal amplification: embed `A` into the algebra of operators on `H^n`
   via `diagonalStarAlgHom`, and show that `diagonal T` lies in the double commutant of the
   amplified algebra `Aamp`.
4. Use that membership in the double commutant implies `diagonal T` preserves all `Aamp`-reducing
   subspaces; in particular it sends a distinguished vector `x` into the cyclic reducing subspace
   `cyclicSubspace Aamp x`.
5. By construction, the separating functional vanishes on `A`, hence on the cyclic subspace;
   therefore `f(T) = 0`, contradicting the separation.
-/

@[expose] public section

namespace WOTClosedSubalgebra

open InnerProductSpace WeakOperatorTopology

variable {H : Type*} [NormedAddCommGroup H] [InnerProductSpace ℂ H] [CompleteSpace H]

local notation "B" => (H →L[ℂ] H)
local notation "BWOT" => (H →WOT[ℂ] H)

/-!
## Cyclic reducing subspaces

For a `StarSubalgebra` `A` and a vector `x`, the closed subspace generated by the orbit `A • x`
is reducing for `A`. Consequently, any operator in `reducingHull A` sends `x` back into this
cyclic reducing subspace.

This is the core invariant-subspace ingredient in the classical “projection” approach.
-/

noncomputable def cyclicSubspace (A : StarSubalgebra ℂ B) (x : H) : Submodule ℂ H :=
  (Submodule.span ℂ (Set.range fun a : A => (a : B) x)).topologicalClosure

lemma subset_cyclicSubspace (A : StarSubalgebra ℂ B) (x : H) :
    (Set.range fun a : A => (a : B) x) ⊆ cyclicSubspace (H := H) A x := by
  intro y hy
  let S : Submodule ℂ H := Submodule.span ℂ (Set.range fun a : A => (a : B) x)
  have : y ∈ S := Submodule.subset_span hy
  exact (Submodule.le_topologicalClosure S) this

lemma mem_cyclicSubspace (A : StarSubalgebra ℂ B) (x : H) : x ∈ cyclicSubspace (H := H) A x := by
  -- Use `1 ∈ A`.
  have hx : (x : H) ∈ Set.range (fun a : A => (a : B) x) := by
    refine ⟨(1 : A), ?_⟩
    simp
  exact (subset_cyclicSubspace (H := H) A x) hx

lemma isInvariant_cyclicSubspace_of_mem (A : StarSubalgebra ℂ B) (x : H) (a : B)
    (ha : a ∈ (A : Set B)) :
    IsInvariant a (cyclicSubspace (H := H) A x) := by
  -- Work with the dense submodule `span (A • x)`.
  let S : Submodule ℂ H := Submodule.span ℂ (Set.range fun b : A => (b : B) x)
  have hS : S.map (a : H →ₗ[ℂ] H) ≤ S := by
    -- Show `a` sends generators back to generators, then extend by `span_induction`.
    intro z hz
    rcases (Submodule.mem_map).1 hz with ⟨y, hyS, rfl⟩
    -- `y ∈ span`.
    refine Submodule.span_induction (p := fun y _ => a y ∈ S)
      (s := Set.range fun b : A => (b : B) x)
      (mem := ?_) (zero := by simp)
      (add := ?_) (smul := ?_) hyS
    · intro y hy
      rcases hy with ⟨b, rfl⟩
      -- `a * b ∈ A`.
      have hab : a * (b : B) ∈ (A : Set B) := by
        -- Coerce `b : A` to `B`.
        -- `ha` provides `a ∈ A` and `A` is a subalgebra.
        simpa using (A.mul_mem ha b.property)
      -- Package `a*b` back as an element of `A`.
      refine Submodule.subset_span ?_
      refine ⟨⟨a * (b : B), hab⟩, ?_⟩
      -- Evaluate.
      simp [ContinuousLinearMap.mul_apply]
    · intro u v hu hv hu' hv'
      simpa [map_add] using S.add_mem hu' hv'
    · intro c u hu hu'
      simpa [map_smul] using S.smul_mem c hu'
  -- Pass to closures using `topologicalClosure_map`.
  have hclosure : (cyclicSubspace (H := H) A x).map (a : H →ₗ[ℂ] H) ≤ cyclicSubspace (H := H) A x := by
    -- `topologicalClosure_map` is phrased as `S.topologicalClosure.map f ≤ (S.map f).topologicalClosure`.
    have hmap := (Submodule.topologicalClosure_map (R₁ := ℂ) (R₂ := ℂ)
      (σ₁₂ := RingHom.id ℂ) (f := (a : B)) (s := S))
    -- Rewrite `cyclicSubspace` as `S.topologicalClosure`.
    dsimp [cyclicSubspace, S] at hmap ⊢
    -- Use `S.map a ≤ S`.
    exact le_trans hmap (Submodule.topologicalClosure_mono (R := ℂ) (M := H) hS)
  -- Convert the submodule map statement to pointwise invariance.
  refine (IsInvariant.iff_forall_mem (T := a) (K := cyclicSubspace (H := H) A x)).2 ?_
  intro y hy
  -- `a y` lies in the mapped submodule.
  have : a y ∈ (cyclicSubspace (H := H) A x).map (a : H →ₗ[ℂ] H) :=
    (Submodule.mem_map).2 ⟨y, hy, rfl⟩
  exact hclosure this

lemma isReducing_cyclicSubspace (A : StarSubalgebra ℂ B) (x : H) :
    IsReducing (H := H) (A : Set B) (cyclicSubspace (H := H) A x) := by
  intro a ha
  refine ⟨?_, ?_⟩
  · exact isInvariant_cyclicSubspace_of_mem (H := H) (A := A) (x := x) (a := a) ha
  · -- Use `A` is star-closed.
    have ha' : ContinuousLinearMap.adjoint a ∈ (A : Set B) := by
      -- `star` on `B` is adjoint.
      have : (star a) ∈ (A : Set B) := A.star_mem' ha
      simpa [ContinuousLinearMap.star_eq_adjoint] using this
    -- Now apply invariance to `a†`.
    simpa using
      (isInvariant_cyclicSubspace_of_mem (H := H) (A := A) (x := x)
        (a := ContinuousLinearMap.adjoint a) ha')

/-- `T` preserves the reducing subspaces for `S` if it leaves invariant every `S`-reducing subspace
(and also its orthogonal complement). -/
def PreservesReducingSubspaces (S : Set (B)) (T : B) : Prop :=
  ∀ (K : Submodule ℂ H) [K.HasOrthogonalProjection],
    IsReducing (H := H) S K → IsInvariant T K ∧ IsInvariant T Kᗮ

lemma mem_cyclicSubspace_of_preservesReducingSubspaces (A : StarSubalgebra ℂ B) {T : B}
    (hT : PreservesReducingSubspaces (H := H) (A : Set B) T) (x : H) :
    T x ∈ cyclicSubspace (H := H) A x := by
  classical
  -- Provide the orthogonal projection instance for the closed cyclic subspace.
  let K : Submodule ℂ H := cyclicSubspace (H := H) A x
  have hKclosed : IsClosed (K : Set H) := by
    -- `topologicalClosure` is closed.
    dsimp [K, cyclicSubspace]
    exact
      Submodule.isClosed_topologicalClosure
        (s := Submodule.span ℂ (Set.range fun a : A => (a : B) x))
  letI : IsClosed (K : Set H) := hKclosed
  letI : CompleteSpace K := (show CompleteSpace (↥(K : Set H)) from inferInstance)
  letI : K.HasOrthogonalProjection := by infer_instance
  have hx : x ∈ K := mem_cyclicSubspace (H := H) A x
  have hRed : IsReducing (H := H) (A : Set B) K := isReducing_cyclicSubspace (H := H) A x
  have hInv : IsInvariant T K := (hT K hRed).1
  exact (IsInvariant.iff_forall_mem (T := T) (K := K)).1 hInv x hx

/-- The (reducing) "AlgLat"-hull of `S`: operators preserving every `S`-reducing subspace.

This is an intermediate object used in the classical proof of the double commutant theorem.
We use reducing subspaces (invariance under `S` and `S†`) so that orthogonal projections commute
with `S` (see `InvariantSubspace.lean`). -/
def reducingHull (S : Set (B)) : Set (B) :=
  {T | PreservesReducingSubspaces (H := H) S T}

/-- Any element of the double commutant preserves all `S`-reducing subspaces.

This is the easy structural part of the hard half: if `T ∈ S''` and `K` is reducing for `S`, then
`T` commutes with the orthogonal projection onto `K`, hence `T` leaves `K` invariant.
-/
lemma preservesReducingSubspaces_of_mem_centralizer_centralizer
    (S : Set (B)) {T : B}
    (hT : T ∈ Set.centralizer (Set.centralizer S)) :
    PreservesReducingSubspaces (H := H) S T := by
  intro K _ hK
  have hP : K.starProjection ∈ Set.centralizer S :=
    starProjection_mem_centralizer_of_isReducing (H := H) (S := S) (K := K) hK
  have hcomm0 := hT K.starProjection hP
  have hcomm : K.starProjection * T = T * K.starProjection := by
    simpa using hcomm0
  refine ⟨isInvariant_of_commutes_starProjection (T := T) (K := K) hcomm,
    isInvariant_orthogonal_of_commutes_starProjection (T := T) (K := K) hcomm⟩

/-- Set-level form: the double commutant is contained in the reducing hull. -/
lemma centralizer_centralizer_subset_reducingHull (S : Set (B)) :
    Set.centralizer (Set.centralizer S) ⊆ reducingHull (H := H) S := by
  intro T hT
  exact preservesReducingSubspaces_of_mem_centralizer_centralizer (H := H) (S := S) hT

/-- Hard direction of the double commutant theorem: a WOT-closed `*-`subalgebra is a double commutant.

This is stated as a set equality of commutants.
-/
theorem doubleCommutant_eq_of_isWOTClosed (A : StarSubalgebra ℂ B)
    (hA : IsWOTClosed (H := H) (A : Set B)) :
    Set.centralizer (Set.centralizer (A : Set B)) = (A : Set B) := by
  classical
  refine le_antisymm ?_ ?_
  · intro T hT
    by_contra hTA
    -- Move to the WOT type-copy.
    let AWOT : Submodule ℂ BWOT := submoduleToWOT (H := H) A.toSubmodule
    have hclosed : IsClosed (AWOT : Set BWOT) := by
      have : (AWOT : Set BWOT) = Set.toWOT (H := H) (A : Set B) := by
        ext S
        simp [AWOT, Set.mem_toWOT_iff, mem_submoduleToWOT_iff (H := H) A.toSubmodule S]
      simpa [this] using hA
    let TWOT : BWOT := (toWOTEquiv (H := H)) T
    have hTWOT : TWOT ∉ (AWOT : Set BWOT) := by
      intro hmem
      have : (toWOTEquiv (H := H)).symm TWOT ∈ A.toSubmodule :=
        (mem_submoduleToWOT_iff (H := H) A.toSubmodule TWOT).1 hmem
      exact hTA this
    obtain ⟨I, coeff, hvan, hneq⟩ :=
      exists_wotCLM_sep_of_isClosed_submodule_sum (H := H) (A := AWOT) hclosed (T := TWOT) hTWOT
    -- The separating functional.
    let f : BWOT →L[ℂ] ℂ :=
      ∑ i : ↥I, (coeff i) • ((ContinuousLinearMap.proj i).comp (inducingFnRestrictCLM (H := H) I))
    -- Convert the separating functional to a finite sum of inner products via amplification.
    have hIne : I.Nonempty := by
      by_contra hI
      simp only [Finset.not_nonempty_iff_eq_empty] at hI
      subst hI
      -- Then `f = 0`, contradicting `hneq`.
      have hf0 : f TWOT = 0 := by
        simp [f]
      exact hneq hf0
    haveI : Nonempty (↥I) := ⟨⟨hIne.choose, hIne.choose_spec⟩⟩
    let n : ℕ := Fintype.card (↥I)
    have hnpos : 0 < n := by
      -- `Fintype.card_pos` gives `0 < Fintype.card ↥I`.
      simpa [n] using (Fintype.card_pos : 0 < Fintype.card (↥I))
    -- Avoid typeclass search for `Nonempty (Fin n)`.
    haveI : Nonempty (Fin n) := ⟨⟨0, hnpos⟩⟩
    let e : Fin n ≃ (↥I) := (Fintype.equivFin (↥I)).symm
    let xFun : Fin n → H := fun i => (e i).1.1
    let uFun : Fin n → H := fun i =>
      (starRingEnd ℂ (coeff (e i))) • (InnerProductSpace.toDual ℂ H).symm ((e i).1.2)
    let x : Hn (H := H) n := (WithLp.equiv _ _).symm xFun
    let u : Hn (H := H) n := (WithLp.equiv _ _).symm uFun
    let Aamp : StarSubalgebra ℂ (Hn (H := H) n →L[ℂ] Hn (H := H) n) :=
      A.map (diagonalStarAlgHom (H := H) n)
    let g : (Hn (H := H) n) →L[ℂ] ℂ :=
      (InnerProductSpace.toDual ℂ (Hn (H := H) n)) u
    have h_eval (S : B) :
        f ((toWOTEquiv (H := H)) S) = g (diagonal (H := H) (n := n) S x) := by
      classical
      have hg : g (diagonal (H := H) (n := n) S x) =
          ∑ i : Fin n, @inner ℂ H _ (uFun i) (S (xFun i)) := by
        simp only [g, u, x]
        rw [InnerProductSpace.toDual_apply_apply, PiLp.inner_apply]
        congr 1
        funext i
        simp only [diagonal_apply, uFun, xFun, WithLp.equiv_symm_apply]
      have hf : f ((toWOTEquiv (H := H)) S) =
          ∑ i : Fin n, @inner ℂ H _ (uFun i) (S (xFun i)) := by
        classical
        have hsum : (∑ j : (↥I),
            (coeff j) • ((inducingFnRestrictCLM (H := H) I) ((toWOTEquiv (H := H)) S) j)) =
            ∑ i : Fin n,
              (coeff (e i)) •
                ((inducingFnRestrictCLM (H := H) I) ((toWOTEquiv (H := H)) S) (e i)) := by
          have :=
            Equiv.sum_comp e
              (fun j : (↥I) =>
                (coeff j) • ((inducingFnRestrictCLM (H := H) I) ((toWOTEquiv (H := H)) S) j))
          simpa using this.symm
        conv_lhs =>
          rw [show f = ∑ i : ↥I,
            (coeff i) • ((ContinuousLinearMap.proj i).comp (inducingFnRestrictCLM (H := H) I)) from rfl]
        simp only [ContinuousLinearMap.sum_apply, ContinuousLinearMap.smul_apply,
          ContinuousLinearMap.comp_apply, ContinuousLinearMap.proj_apply]
        rw [show (∑ i : ↥I, coeff i • (inducingFnRestrictCLM (H := H) I) (toWOTEquiv S) i) =
            ∑ i : Fin n, coeff (e i) • (inducingFnRestrictCLM (H := H) I) (toWOTEquiv S) (e i) from hsum]
        simp only [inducingFnRestrictCLM, inducingFnCLM, restrictPiCLM,
          ContinuousLinearMap.comp_apply, ContinuousLinearMap.coe_mk', LinearMap.coe_mk,
          AddHom.coe_mk]
        congr 1
        funext i
        rw [ContinuousLinearMapWOT.inducingFn_apply]
        simp only [toWOTEquiv, ContinuousLinearMap.toWOT_apply]
        conv_lhs =>
          rw [show (e i).1.2 (S (e i).1.1) =
            @inner ℂ H _ ((InnerProductSpace.toDual ℂ H).symm (e i).1.2) (S (e i).1.1) from
            InnerProductSpace.toDual_symm_apply.symm]
        simp only [uFun, xFun, inner_smul_left, starRingEnd_self_apply, smul_eq_mul]
      simpa [hg] using hf
    -- The separating functional `f` vanishes on the amplified algebra `Aamp`.
    have hg_on_range : ∀ a : Aamp,
        g ((a : (Hn (H := H) n →L[ℂ] Hn (H := H) n)) x) = 0 := by
      intro a
      rcases a with ⟨a0, ha0⟩
      rcases ha0 with ⟨S, hSA, rfl⟩
      have : f ((toWOTEquiv (H := H)) (S : B)) = 0 := by
        apply hvan
        have : (toWOTEquiv (H := H)) (S : B) ∈ (AWOT : Set BWOT) := by
          exact
            (mem_submoduleToWOT_iff (H := H) A.toSubmodule ((toWOTEquiv (H := H)) (S : B))).2 hSA
        exact this
      simpa [h_eval] using this
    -- Extend vanishing from generators to the entire cyclic subspace by continuity.
    have hg_on_cyclic : ∀ z : Hn (H := H) n,
        z ∈ cyclicSubspace (H := Hn (H := H) n) (A := Aamp) x →
          g z = 0 := by
      intro z hz
      let Ssub : Submodule ℂ (Hn (H := H) n) :=
        Submodule.span ℂ (Set.range fun a : Aamp =>
          (a : (Hn (H := H) n →L[ℂ] Hn (H := H) n)) x)
      have hz' : z ∈ Ssub.topologicalClosure := by
        simpa [cyclicSubspace, Ssub] using hz
      have hgS : ∀ w, w ∈ Ssub → g w = 0 := by
        intro w hw
        refine Submodule.span_induction (p := fun w _ => g w = 0)
          (s := Set.range fun a : Aamp =>
            (a : (Hn (H := H) n →L[ℂ] Hn (H := H) n)) x)
          (mem := ?_) (zero := by simp [g]) (add := ?_) (smul := ?_) hw
        · intro w hw
          rcases hw with ⟨a, rfl⟩
          simpa using hg_on_range a
        · intro u v _ _ hu hv
          simpa [map_add] using congr_arg₂ (fun p q => p + q) hu hv
        · intro c v _ hv
          simpa [map_smul] using congrArg (fun t => c • t) hv
      have hclosedKer : IsClosed {w | g w = 0} := isClosed_eq (g.continuous) continuous_const
      have : z ∈ {w | g w = 0} := by
        refine hclosedKer.closure_subset_iff.2 ?_ hz'
        intro w hw
        exact hgS w hw
      simpa using this
    -- The diagonal embedding of `T` lies in the double commutant of `Aamp`.
    have hdiag_mem :
        diagonal (H := H) (n := n) T ∈
          Set.centralizer (Set.centralizer ((Aamp : StarSubalgebra ℂ _ ) : Set _)) := by
      have hT' : T ∈ Set.centralizer (Set.centralizer (A : Set B)) := hT
      have hdiag : diagonal (H := H) (n := n) T ∈
          (diagonal (H := H) (n := n) '' (A : Set B)).centralizer.centralizer :=
        diagonal_mem_double_commutant (H := H) (n := n) (A := (A : Set B)) (T := T) hT'
      simpa [Aamp, diagonalStarAlgHom] using hdiag
    -- By the double commutant membership, `diagonal T` preserves all `Aamp`-reducing subspaces.
    have hPres : PreservesReducingSubspaces
        (H := Hn (H := H) n)
        (Aamp : Set (Hn (H := H) n →L[ℂ] Hn (H := H) n))
        (diagonal (H := H) (n := n) T) :=
      preservesReducingSubspaces_of_mem_centralizer_centralizer
        (H := Hn (H := H) n)
        (S := (Aamp : Set (Hn (H := H) n →L[ℂ] Hn (H := H) n)))
        (T := diagonal (H := H) (n := n) T)
        hdiag_mem
    -- Key step: `diagonal T` sends `x` into the cyclic subspace generated by `Aamp • x`.
    have hxmem : diagonal (H := H) (n := n) T x ∈
        cyclicSubspace (H := Hn (H := H) n) (A := Aamp) x := by
      simpa using
        mem_cyclicSubspace_of_preservesReducingSubspaces
          (H := Hn (H := H) n)
          (A := Aamp)
          (T := diagonal (H := H) (n := n) T)
          hPres x
    -- Conclude: `f(T) = 0` since `g` vanishes on the cyclic subspace containing `diagonal T x`.
    have : f ((toWOTEquiv (H := H)) T) = 0 := by
      have : g (diagonal (H := H) (n := n) T x) = 0 := hg_on_cyclic _ hxmem
      simpa [h_eval] using this
    -- Contradiction: `f(T) ≠ 0` was our separation hypothesis.
    exact hneq (by simp only [TWOT, f] at this ⊢; exact this)
  · exact Set.subset_centralizer_centralizer

end WOTClosedSubalgebra
